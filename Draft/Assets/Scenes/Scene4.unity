  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'A violent headache strikes, and my memories return in an instant.


    The
    painter died a week ago.


    I was never a dream therapist.

    I am only
    an ordinary psychologist.


    After cutting off his ear, the painter took his
    own life. The incident left me with severe psychological trauma. Since then,
    I have suffered from insomnia and bought sleeping pills that were banned from
    the market.


    Their side effects were hallucinations and memory loss.


    Everything
    that happened from the beginning of the game until now was part of my hallucination.


    The
    dream was never his.

    It belonged to me all along.


    Now, I face my final
    two choices:


    Take the pills,

    or walk out of this room.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
